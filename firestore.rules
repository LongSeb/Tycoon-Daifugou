rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /lobbies/{lobbyId} {
      // Any authenticated user can read lobbies (needed to observe lobby status changes)
      allow read: if request.auth != null;
      // All lobby writes go through Cloud Functions (admin SDK bypasses these rules)
      allow write: if false;
    }

    match /players/{uid} {
      allow read: if request.auth != null;
      // Users can only write their own document; multiplayer fields (elo, rank) are
      // written exclusively by Cloud Functions using the admin SDK
      allow write: if request.auth.uid == uid;
    }

    match /usernames/{username} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
